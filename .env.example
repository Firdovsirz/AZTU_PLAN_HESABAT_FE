# Copy this file to .env and fill in real values. NEVER commit the real .env.
# Vite only exposes variables prefixed with VITE_ to the browser bundle, so
# never put secrets here — anything in here ships to the client.

# Base URL of the AZTU Plan Hesabat backend API (no trailing slash).
VITE_BASE_URL=https://api-plan-report.aztu.edu.az
